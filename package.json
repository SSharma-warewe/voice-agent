{
  "name": "voice-repo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev:api": "pnpm --filter @voice-repo/api dev",
    "dev:agent": "pnpm --filter @voice-repo/agent dev",
    "dev:agent:lead": "pnpm --filter @voice-repo/agent exec node src/lead/main.ts dev",
    "dev:agent:booking": "pnpm --filter @voice-repo/agent exec node src/booking/main.ts dev",
    "dev:worker": "pnpm --filter @voice-repo/worker dev",
    "dev:web": "pnpm --filter @voice-repo/web dev",
    "start:api": "pnpm --filter @voice-repo/api start",
    "start:agent": "pnpm --filter @voice-repo/agent start",
    "start:agent:lead": "pnpm --filter @voice-repo/agent exec node src/lead/main.ts start",
    "start:agent:booking": "pnpm --filter @voice-repo/agent exec node src/booking/main.ts start",
    "start:worker": "pnpm --filter @voice-repo/worker start",
    "start:web": "pnpm --filter @voice-repo/web start",
    "start:all": "node scripts/railway-start.mjs",
    "start:railway": "node scripts/railway-start.mjs",
    "build:agent": "pnpm --filter @voice-repo/agent typecheck",
    "build:web": "pnpm --filter @voice-repo/web build",
    "test:agent": "pnpm --filter @voice-repo/agent test"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
