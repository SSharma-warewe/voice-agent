# Express API
SERVER_PORT=6080
# Local/dev: use an isolated DB (e.g. voice_repo_local) so workers/agents never
# mutate the Railway/production database (typically `neondb`).
# Create with: node scripts/ensure-local-db.mjs
# Railway/deploy must keep DATABASE_URL pointed at the production DB name.
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/voice_repo_local?sslmode=require

# pg-boss worker (packages/worker)
WORKER_POLL_INTERVAL_MS=30000
# false (default): worker only requeues stuck outbound calls.
# Outbound rooms are started by the real UI queue (POST /queue/*/start).
# true: worker also auto-dispatches pending outbound appointments/leads.
WORKER_AUTO_DISPATCH=false
# Outbound only (confirmation + lead). Inbound booking is separate (POST /booking/start, no queue).
MAX_CONCURRENT_CALLS=2          # total outbound concurrent calls
MAX_CONFIRMATION_CALLS=1        # appointment-confirmation-agent slots
MAX_LEAD_CALLS=1                # lead-outreach-agent slots

# LiveKit (worker, api, agent — apps/agent can also use .env.local)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Browser app (apps/web)
VITE_API_URL=/api
# Set true only for offline UI demos (fake data + no real LiveKit join)
VITE_USE_MOCKS=false

# Agent status updates (apps/agent)
API_URL=http://localhost:6080

# Calendar integration (Nylas token for Google Calendar sync in agents)
# Used by confirmation agent for availability checks + auto create/update/cancel events.
CALENDAR_URL=your-nylas-token
# Optional: override timezone for date calculations (default Asia/Kolkata)
# CALENDAR_TIMEZONE=Asia/Kolkata