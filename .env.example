# Express API
SERVER_PORT=6080
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# pg-boss worker (packages/worker) — polls for pending appointments
WORKER_POLL_INTERVAL_MS=30000
MAX_CONCURRENT_CALLS=3

# LiveKit (worker, api, agent — apps/agent can also use .env.local)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Browser app (apps/web)
VITE_API_URL=/api

# Agent status updates (apps/agent)
API_URL=http://localhost:6080