{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rewriteRelativeImportExtensions": true
  },
  "include": ["./src/**/*"],
  "exclude": [
    "./src/**/*.test.ts",
    "./src/**/*.integration.test.ts",
    "./src/test/**/*"
  ]
}